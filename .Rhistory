#extraire fonction
extraire_zone <- function(df, bbox) {
df[
df$longitude >= bbox[1], df$longitude <= bbox[2],
df$latitude  >= bbox[3], df$latitude  <= bbox[4]]
}
# Découpe des 3 zones
dtaMbouzi   <- extraire_zone(dtaScaled, empriseMbouzi)
