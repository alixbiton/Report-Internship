install.packages("spdep")
library(spdep)
# Créer les coordonnées spatiales à partir de ton dataframe
coords <- cbind(dta_train$longitude, dta_train$latitude)
# Créer la matrice de voisinage (k plus proches voisins, ici k=5)
knn     <- knearneigh(coords, k = 5)
# Créer la matrice de voisinage (k plus proches voisins, ici k=5)
knn     <- knearneigh(coords, k = 5)
nb      <- knn2nb(knn)
nb      <- knn2nb(knn)
lw      <- nb2listw(nb, style = "W")  # style "W" = pondération par ligne
moran.test(residuals(m1), lw)
moran.plot(residuals(m1), lw,
main = "Diagramme de Moran - Résidus m1",
xlab = "Résidus", ylab = "Résidus spatialement décalés")
